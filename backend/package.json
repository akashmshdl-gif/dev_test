{
  "name": "eligibilitycheck",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node -e \"console.log('Backend build step complete')\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "setup:dev": "node scripts/ensure-dev-keys.js",
    "dev": "nodemon server.js",
    "generate-jwks": "node scripts/generate-jwks.js",
    "generate-epic-jwks": "node scripts/generate-epic-jwks-bundle.js",
    "db:create": "npx sequelize-cli db:create",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:setup": "npx sequelize-cli db:create && npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "migrate:fresh": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate"
  },
  "keywords": [],
