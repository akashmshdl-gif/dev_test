    "@aws-sdk/client-s3": "^3.842.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "hl7": "^0.0.0",
    "http-status": "^2.1.0",
    "https": "^1.0.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.1",
    "node-cron": "^4.2.0",
